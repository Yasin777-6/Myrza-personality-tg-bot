# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# DeepSeek API Key (from https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Probability (0.0 to 1.0) of responding to general group messages (e.g., 0.15 = 15%)
# Note: The bot will ALWAYS respond to direct mentions or replies to its messages.
REPLY_PROBABILITY=0.15

# Telegram Username / User ID mappings for the friends (comma-separated lists)
# This helps the bot "Myrza" recognize who is talking to him and respond accordingly.
# Fill these with their Telegram usernames (without @) or their numerical Telegram User IDs.
USER_ARTUR=thereisnohopeleftinme
USER_AKTAN=wak_kfu
USER_YASIN=yasin_username
USER_MANSUR=mall1aners
USER_BEKA=ineverwantedanyofit
